# Vapi PUBLIC key (Dashboard → Vapi API Keys → Public Key). Safe for the browser.
VITE_VAPI_PUBLIC_KEY=

# Public URL of the tool server's /api/tools endpoint.
# Vapi's backend calls this, so localhost will NOT work for real calls —
# tunnel it: `ngrok http 3001` then use https://<id>.ngrok.app/api/tools
VITE_TOOL_SERVER_URL=http://localhost:3001/api/tools
