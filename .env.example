# Cursor SDK — create a key at https://cursor.com/dashboard/api
CURSOR_API_KEY=
# Model used by all orchestrated agents (optional)
CURSOR_MODEL=composer-2.5
# Max parallel worker agents per job (optional)
MAX_WORKERS=3

# Google Maps Platform — enable "Places API (New)" and "Routes API" on the key
# https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=

# ElevenLabs Agents — optional / legacy (token endpoint still present)
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# Voice UX (Vapi) — browser keys live in web/.env (see web/.env.example)
# VITE_VAPI_PUBLIC_KEY=
# VITE_TOOL_SERVER_URL=https://<ngrok>.ngrok.app/api/tools

PORT=3001
