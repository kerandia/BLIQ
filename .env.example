# Cursor SDK — create a key at https://cursor.com/dashboard/api
CURSOR_API_KEY=
# Model used by all orchestrated agents (optional)
CURSOR_MODEL=composer-2.5
# Max parallel worker agents per job (optional)
MAX_WORKERS=3

# Google Maps Platform — enable "Places API (New)" and "Routes API" on the key
# https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=

# ElevenLabs Agents — create an agent at https://elevenlabs.io/app/agents
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

PORT=3001
